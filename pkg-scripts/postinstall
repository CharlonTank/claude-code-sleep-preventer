#!/bin/bash

# Configure Claude Code hooks and LaunchAgent for login startup
APP_CLI="/Applications/AgentsSleepPreventer.app/Contents/MacOS/asp"
CLI="/usr/local/bin/asp"

if [ -x "$APP_CLI" ]; then
    install -d /usr/local/bin
    install -m 755 "$APP_CLI" "$CLI"
    install -m 755 "$APP_CLI" /usr/local/bin/agents-sleep-preventer
    "$APP_CLI" install -y
elif [ -x "$CLI" ]; then
    "$CLI" install -y
fi

# Get logged in user
CONSOLE_USER=$(stat -f %Su /dev/console)

# Try to launch the app in the user's context using su (not sudo)
su - "$CONSOLE_USER" -c "/usr/bin/open /Applications/AgentsSleepPreventer.app" &

exit 0
